Package: r2u
Type: Package
Title: Turn CRAN Source Packages into Binary Ubuntu Packages
Version: 0.0.9.3
Date: 2025-03-16
Authors@R: person("Dirk", "Eddelbuettel", role = c("aut", "cre"), email = "edd@debian.org",
